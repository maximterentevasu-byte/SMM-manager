# ==============================================
# СКОПИРУЙ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИ ЗНАЧЕНИЯ
# Команда: cp .env.example .env
# ==============================================

# --- База данных ---
POSTGRES_PASSWORD=придумай_сложный_пароль_123
DATABASE_URL=postgresql://smm_user:придумай_сложный_пароль_123@postgres:5432/smm_platform

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Безопасность (JWT токены) ---
# Сгенерируй случайную строку: openssl rand -hex 32
SECRET_KEY=замени_на_случайную_строку_минимум_32_символа

# --- Шифрование токенов соцсетей ---
# Сгенерируй командой внутри контейнера:
# docker-compose run --rm backend python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=замени_на_сгенерированный_ключ

# --- AI API ---
# Получи на https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- ВКонтакте ---
# Создай приложение на https://vk.com/editapp?act=create
VK_APP_ID=
VK_APP_SECRET=

# --- Хранилище картинок (Yandex Object Storage) ---
# Создай бакет на https://console.yandex.cloud/
S3_BUCKET=smm-platform-media
S3_ENDPOINT=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central1

# --- Необязательно на старте ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
